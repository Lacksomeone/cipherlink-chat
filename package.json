{
  "name": "cipherlink-e2ee-chat",
  "version": "2.0.0",
  "private": true,
  "description": "Production-ready E2EE chat with WebRTC calling, glassmorphism UI, and real-time messaging",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node server.js",
    "dev:client": "npm run dev --prefix client",
    "postinstall": "npm install --prefix client",
    "build": "npm run build --prefix client",
    "start": "node server.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
