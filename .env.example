# ─────────────────────────────────────────────────
# CipherLink E2EE Chat — Environment Variables
# Copy this file to `.env` and fill in values.
# ─────────────────────────────────────────────────

# App environment: production | development
NODE_ENV=development

# HTTP port for Express + Socket.io
PORT=3001

# JWT secret (REQUIRED in production, dev uses fallback)
JWT_SECRET=replace-with-a-64-char-random-secret

# SQLite database path
SQLITE_PATH=./data.sqlite

# CORS origin for frontend (leave blank in dev for Vite proxy)
CLIENT_ORIGIN=

# Supabase (optional — for PostgreSQL migration)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key

# TURN/STUN servers for WebRTC (optional, defaults to Google STUN)
# TURN_SERVER_URL=turn:your-turn-server.com:3478
# TURN_USERNAME=your-turn-username
# TURN_CREDENTIAL=your-turn-credential
